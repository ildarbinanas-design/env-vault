    "env-vault-linux-arm64.tar.gz.sha256",
    "env-vault-darwin-amd64.tar.gz",
    "env-vault-darwin-amd64.tar.gz.sha256",
    "env-vault-darwin-arm64.tar.gz",
    "env-vault-darwin-arm64.tar.gz.sha256",
    "env-vault-windows-amd64.zip",
    "env-vault-windows-amd64.zip.sha256"
  ],
  "workflows": [
    { "id": "ci", "name": "ci", "file": "ci.yml" },
    { "id": "quality", "name": "reusable-quality", "file": "reusable-quality.yml" },
    { "id": "planning", "name": "release-please", "file": "release-please.yml" },
    { "id": "publisher", "name": "build-binaries", "file": "build-binaries.yml" },
    { "id": "release_evidence", "name": "release-evidence", "file": "release-evidence.yml" },
    { "id": "legacy_rebuild", "name": "legacy-rebuild", "file": "legacy-rebuild.yml" },
    { "id": "pr_title", "name": "pr-title", "file": "pr-title.yml" },
    { "id": "dependency_review", "name": "Dependency review", "file": "dependency-review.yml" },
    { "id": "planning_app_audit", "name": "audit-release-planning-app", "file": "audit-release-planning-app.yml" },
    { "id": "tap_app_audit", "name": "audit-release-app", "file": "audit-release-app.yml" }
  ],
  "apps": [
    {
      "id": "release_planning",
      "slug": "env-vault-release-planning",
      "repository": "ildarbinanas-design/env-vault",
      "environment": "release-planning",
      "audit_workflow": "planning_app_audit"
    },
    {
      "id": "homebrew_tap",
      "slug": "env-vault-tap-release",
      "repository": "ildarbinanas-design/homebrew-tap",
      "environment": "release",
      "audit_workflow": "tap_app_audit",
      "ci_workflow_file": "test-formula.yml",
      "ci_workflow_name": "test-formula"
    }
  ],
  "capabilities": {
    "observation": [
      { "id": "release.plan", "transport": "github_api", "http_methods": ["GET"] },
      { "id": "release.status", "transport": "github_api", "http_methods": ["GET"] },
      { "id": "release.watch", "transport": "github_api", "http_methods": ["GET"] },
      { "id": "release.verify", "transport": "github_api", "http_methods": ["GET"] },
      { "id": "release.metrics", "transport": "github_api", "http_methods": ["GET"] },
      { "id": "release.repair.plan", "transport": "github_api", "http_methods": ["GET"] },
      { "id": "release.legacy_rebuild.plan", "transport": "github_api", "http_methods": ["GET"] }
    ],
    "mutation": [
      {
        "id": "release.repair.apply",
        "dry_run_default": true,
        "requires_plan_digest": true,
        "requires_remote_preconditions": true,
        "idempotent": true
      },
      {
        "id": "release.legacy_rebuild.apply",
        "dry_run_default": true,
        "requires_plan_digest": true,
        "requires_remote_preconditions": true,
        "idempotent": true
      }
    ]
  },
  "release_stages": [
    { "id": "source_quality", "ordinal": 1, "workflow": "ci", "state_mutating": false },
    { "id": "exact_version_artifact_quality", "ordinal": 2, "workflow": "quality", "state_mutating": false },
    { "id": "planning", "ordinal": 3, "workflow": "planning", "state_mutating": true },
    { "id": "publication", "ordinal": 4, "workflow": "publisher", "state_mutating": true },
    { "id": "supply_chain", "ordinal": 5, "workflow": "publisher", "state_mutating": true },
    { "id": "homebrew", "ordinal": 6, "workflow": "publisher", "state_mutating": true },
    { "id": "health", "ordinal": 7, "workflow": "publisher", "state_mutating": false }
  ],
  "repair_modes": [
    { "code": "none", "resume_stage": "publication", "rebuilds": false, "state_mutating": true },
    { "code": "release-assets", "resume_stage": "publication", "rebuilds": false, "state_mutating": true },
    { "code": "homebrew", "resume_stage": "homebrew", "rebuilds": false, "state_mutating": true },
    { "code": "health", "resume_stage": "health", "rebuilds": false, "state_mutating": false }
  ],
  "action_codes": [
    "none",
    "wait_tag",
    "wait_main_ci",
    "wait_planning",
    "wait_publisher",
    "wait_release_assets",
    "wait_supply_chain",
    "wait_homebrew",
    "wait_health",
    "rerun_all_jobs",
    "rerun_tap_pr_ci_all_jobs",
    "rerun_tap_post_merge_ci_all_jobs",
    "wait_tap_ci",
    "replan_publisher",
    "dispatch_legacy_rebuild",
    "dispatch_release_assets_repair",
    "dispatch_homebrew_repair",
    "dispatch_health_repair",
    "inspect_main_ci_failure",
    "inspect_planning_failure",
    "inspect_publisher_failure",
    "inspect_release_failure",
    "inspect_supply_chain_failure",
    "inspect_homebrew_failure",
    "inspect_health_failure",
    "resolve_inconsistency"
  ],
  "error_codes": [
    "CONTRACT_INVALID",
    "INPUT_INVALID",
    "AUTH_REQUIRED",
    "AUTH_FORBIDDEN",
